local deleteObstaclesEnabled = false

local function startDeletingObstacles()
    task.spawn(function()
        while deleteObstaclesEnabled do
            local fx = workspace:FindFirstChild("Fx")
            if fx then
                for _, obj in ipairs(fx:GetChildren()) do
                    pcall(function() obj:Destroy() end)
                end
            end
            task.wait(0.1)
        end
    end)
end

MiscTab:CreateToggle({
    Name = "Delete Obstacles",
    CurrentValue = false,
    Flag = "DeleteObstacles",
    Callback = function(Value)
        deleteObstaclesEnabled = Value
        if Value then
            startDeletingObstacles()
            Rayfield:Notify({ Title = "Obstacles", Content = "Now deleting Workspace.Fx contents.", Duration = 3, Image = 4483345998 })
        else
            Rayfield:Notify({ Title = "Obstacles", Content = "Stopped deleting obstacles.", Duration = 3, Image = 4483345998 })
        end
    end,
})

