--  TAB 1: Auto Steal  (random Rare+, no zone logic)
-- ═══════════════════════════════════════
local StealTab = Window:CreateTab("Auto Steal", 4483345998)

local IGNORED_RARITIES_AUTO = {
    ["common"] = true, ["uncommon"] = true, ["epic"] = true,
}

local selectedBrainrot = ""
local manualBrainrotName = ""
local cachedBrainrots = getWildBrainrotsAll()
local autoModeEnabled = false

local function getManualTarget()
    return (selectedBrainrot ~= "" and selectedBrainrot ~= "None found")
        and selectedBrainrot or manualBrainrotName
end

local function startAutoMode()
    task.spawn(function()
        Rayfield:Notify({
            Title = "Auto Mode ON",
            Content = "Stealing random Rare+ brainrots.",
            Duration = 3,
            Image = 4483345998,
        })

        while autoModeEnabled do
            -- Scan Wild, skip common/uncommon/epic
            local all = getWildBrainrotsAll()
            local filtered = {}
            for name, data in pairs(all) do
                if not IGNORED_RARITIES_AUTO[data.rarity] then
                    filtered[name] = data
                end
            end

            if next(filtered) == nil then
                task.wait(2)
            else
                local target = pickRandom(filtered)
                if target then
                    doSteal(target, true)
                    task.wait(0.5)
                end
            end
        end

        Rayfield:Notify({ Title = "Auto Mode OFF", Content = "Loop stopped.", Duration = 3, Image = 4483345998 })
    end)
end

