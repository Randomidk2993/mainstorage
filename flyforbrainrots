-- ═══════════════════════════════════════
--  SHARED HELPERS
-- ═══════════════════════════════════════

local myPlotNumber = 1
local holdDuration = 1.0

local function getPlayerBase()
    local plotName = "Plot" .. myPlotNumber
    local plot = workspace:FindFirstChild("Plots")
        and workspace.Plots:FindFirstChild(plotName)
    if not plot then return nil end
    if plot:IsA("BasePart") then return plot end
    for _, child in ipairs(plot:GetDescendants()) do
        if child:IsA("BasePart") then return child end
    end
    return nil
end

local function getBrainrotRarity(model)
    local root = model:FindFirstChild("Root")
    if not root then return "" end
    local billboard = root:FindFirstChild("BillboardGui")
    if not billboard then return "" end
    local rarityLabel = billboard:FindFirstChild("Rarity")
    if not rarityLabel then return "" end
    return rarityLabel.Text:lower():gsub("%s+", "")
end

-- Returns all valid brainrots in Wild, optionally filtered to a specific rarity
-- filterRarity = nil means return all
-- filterRarity = "rare" means only return brainrots of that rarity
local function getWildBrainrots(filterRarity)
    local wildFolder = workspace:FindFirstChild("Wild")
    local result = {}
    if not wildFolder then return result end

    for _, model in ipairs(wildFolder:GetChildren()) do
        local root = model:FindFirstChild("Root")
        if root and root:IsA("BasePart") then
            local prompt = root:FindFirstChild("CarryPrompt")
            if prompt and prompt:IsA("ProximityPrompt") then
                local rarity = getBrainrotRarity(model)
                if not filterRarity or rarity == filterRarity then
                    result[model.Name] = { root = root, prompt = prompt, rarity = rarity }
                end
            end
        end
    end
    return result
end

-- All brainrots, no filter (for manual dropdown)
local function getWildBrainrotsAll()
    return getWildBrainrots(nil)
end

local function getBrainrotNames(brainrotTable)
    local names = {}
    for name, _ in pairs(brainrotTable) do
        table.insert(names, name)
    end
    table.sort(names)
    if #names == 0 then table.insert(names, "None found") end
    return names
end

local function pickRandom(brainrotTable)
    local keys = {}
    for name, _ in pairs(brainrotTable) do
        table.insert(keys, name)
    end
    if #keys == 0 then return nil end
    return keys[math.random(1, #keys)]
end

local function getZonePart(zoneKey)
    return workspace:FindFirstChild("Zones")
        and workspace.Zones:FindFirstChild("Spawn")
        and workspace.Zones.Spawn:FindFirstChild(zoneKey)
end

local function getHubPart(name)
    return workspace:FindFirstChild("MAIN_ARIGATO")
        and workspace.MAIN_ARIGATO:FindFirstChild("parts")
        and workspace.MAIN_ARIGATO.parts:FindFirstChild(name)
end

-- Teleport HRP to a BasePart, offset Y
local function teleportTo(part, offsetY)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local cframe = nil

    if part:IsA("BasePart") then
        cframe = part.CFrame
    elseif part:IsA("Model") and part.PrimaryPart then
        cframe = part.PrimaryPart.CFrame
    else
        for _, c in ipairs(part:GetDescendants()) do
            if c:IsA("BasePart") then cframe = c.CFrame break end
        end
    end

    if cframe then
        hrp.CFrame = cframe * CFrame.new(0, offsetY or 4, 0)
        return true
    end
    return false
end

-- ═══════════════════════════════════════
--  CORE STEAL FUNCTION
-- ═══════════════════════════════════════

local function doSteal(targetName, silentReturn)
    if not targetName or targetName == "" or targetName == "None found" then
        return false, "No brainrot selected."
    end

    local wildFolder = workspace:FindFirstChild("Wild")
    if not wildFolder then return false, "Wild folder not found." end

    local rootPart, carryPrompt = nil, nil
    for _, model in ipairs(wildFolder:GetChildren()) do
        if model.Name:lower() == targetName:lower() then
            local root = model:FindFirstChild("Root")
            if root and root:IsA("BasePart") then
                local prompt = root:FindFirstChild("CarryPrompt")
                if prompt and prompt:IsA("ProximityPrompt") then
                    rootPart = root
                    carryPrompt = prompt
                    break
                end
            end
        end
    end

    if not rootPart then return false, "'" .. targetName .. "' not in Wild." end
    if not carryPrompt then return false, "No CarryPrompt on Root." end

    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    hrp.CFrame = rootPart.CFrame * CFrame.new(0, 2, 0)
    task.wait(0.2)

    carryPrompt:InputHoldBegin()
    task.wait(holdDuration)
    carryPrompt:InputHoldEnd()
    task.wait(0.2)

    local basePart = getPlayerBase()
    if basePart then
        hrp.CFrame = basePart.CFrame * CFrame.new(0, 4, 0)
        return true, "Stolen & returned to Plot " .. myPlotNumber .. "!"
    else
        return true, "Picked up but Plot " .. myPlotNumber .. " not found."
    end
end

