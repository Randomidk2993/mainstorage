--  TAB 3: Zone Teleport (manual)
-- ═══════════════════════════════════════
local ZoneTab = Window:CreateTab("Zones", 4483345998)

local ZONE_LABELS_MAP = {}
for _, z in ipairs(ZONES) do
    ZONE_LABELS_MAP["Zone " .. z.key:match("%d+") .. " - " .. z.label] = z.key
end

local zoneOptions = {}
for label, _ in pairs(ZONE_LABELS_MAP) do
    table.insert(zoneOptions, label)
end
table.sort(zoneOptions)

local hubZoneNames = {
    "Hub - Carry", "Hub - Group", "Hub - Index", "Hub - MaxFuel",
    "Hub - Rebirth", "Hub - Sell", "Hub - Shop", "Hub - Speed", "Hub - Spins",
    "My Base"
}
for _, name in ipairs(hubZoneNames) do
    table.insert(zoneOptions, name)
end

local selectedZone = ""

ZoneTab:CreateDropdown({
    Name = "Select Zone",
    Options = zoneOptions,
    CurrentOption = {"Select a zone..."},
    MultipleOptions = false,
    Flag = "ZoneDropdown",
    Callback = function(Options) selectedZone = Options[1] end,
})

ZoneTab:CreateButton({
    Name = "Teleport to Zone",
    Callback = function()
        if selectedZone == "" then
            Rayfield:Notify({ Title = "Error", Content = "Select a zone first.", Duration = 3, Image = 4483345998 })
            return
        end

        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local targetCFrame = nil

        local zoneKey = ZONE_LABELS_MAP[selectedZone]
        if zoneKey then
            local zonePart = getZonePart(zoneKey)
            if zonePart then
                if zonePart:IsA("BasePart") then
                    targetCFrame = zonePart.CFrame
                else
                    for _, c in ipairs(zonePart:GetDescendants()) do
                        if c:IsA("BasePart") then targetCFrame = c.CFrame break end
                    end
                end
            end
        elseif selectedZone == "My Base" then
            local base = getPlayerBase()
            if base then targetCFrame = base.CFrame end
        else
            local hubName = selectedZone:match("Hub %- (.+)")
            if hubName then
                local part = getHubPart(hubName)
                if part and part:IsA("BasePart") then targetCFrame = part.CFrame end
            end
        end

        if not targetCFrame then
            Rayfield:Notify({ Title = "Not Found", Content = "Could not locate '" .. selectedZone .. "'.", Duration = 4, Image = 4483345998 })
            return
        end

        hrp.CFrame = targetCFrame * CFrame.new(0, 4, 0)
        Rayfield:Notify({ Title = "Teleported!", Content = "Arrived at " .. selectedZone, Duration = 2, Image = 4483345998 })
    end,
})

ZoneTab:CreateLabel("Zone 1=Common  2=Uncommon  3=Rare  4=Epic  5=Legendary  6=Mythic  7=Secret")

