-- ═══════════════════════════════════════
--  TAB 2: Zone Auto Mode
-- ═══════════════════════════════════════
local ZoneAutoTab = Window:CreateTab("Zone Auto", 4483345998)

local zoneAutoEnabled = false

-- Per-zone toggle callbacks
for _, zone in ipairs(ZONES) do
    ZoneAutoTab:CreateToggle({
        Name = zone.label,
        CurrentValue = false,
        Flag = "ZoneToggle_" .. zone.key,
        Callback = function(Value)
            zoneEnabled[zone.key] = Value
        end,
    })
end

-- The zone auto loop:
-- 1. Build list of enabled zones
-- 2. For each enabled zone in order:
--    a. Teleport to the zone spawn point
--    b. Wait a moment for brainrots to be visible
--    c. Scan Wild for brainrots matching that zone's rarity
--    d. If found, pick random one and steal it (returns to base after)
--    e. Move to next enabled zone
-- 3. Repeat from top until stopped

local function startZoneAutoMode()
    task.spawn(function()
        Rayfield:Notify({
            Title = "Zone Auto ON",
            Content = "Cycling enabled zones.",
            Duration = 3,
            Image = 4483345998,
        })

        while zoneAutoEnabled do
            -- Collect currently enabled zones
            local activeZones = {}
            for _, zone in ipairs(ZONES) do
                if zoneEnabled[zone.key] then
                    table.insert(activeZones, zone)
                end
            end

            if #activeZones == 0 then
                -- Nothing enabled, idle
                task.wait(2)
            else
                for _, zone in ipairs(activeZones) do
                    if not zoneAutoEnabled then break end

                    -- Teleport to this zone's spawn
                    local zonePart = getZonePart(zone.key)
                    if zonePart then
                        teleportTo(zonePart, 4)
                        task.wait(0.5) -- settle and let Wild update
                    end

                    -- Scan Wild for brainrots matching this zone's rarity
                    local matching = getWildBrainrots(zone.rarity)

                    if next(matching) ~= nil then
                        local target = pickRandom(matching)
                        if target then
                            -- Notify which rarity we're stealing
                            Rayfield:Notify({
                                Title = "Zone Auto",
                                Content = "Stealing " .. zone.label .. ": " .. target,
                                Duration = 2,
                                Image = 4483345998,
                            })
                            doSteal(target, true)
                            task.wait(0.5)
                        end
                    else
                        -- Nothing of this rarity right now, move on
                        task.wait(0.3)
                    end
                end
            end
        end

        Rayfield:Notify({ Title = "Zone Auto OFF", Content = "Loop stopped.", Duration = 3, Image = 4483345998 })
    end)
end

ZoneAutoTab:CreateToggle({
    Name = "Start Zone Auto",
    CurrentValue = false,
    Flag = "ZoneAutoMode",
    Callback = function(Value)
        zoneAutoEnabled = Value
        if Value then
            -- Require at least one zone enabled
            local anyEnabled = false
            for _, v in pairs(zoneEnabled) do
                if v then anyEnabled = true break end
            end
            if not anyEnabled then
                Rayfield:Notify({
                    Title = "No Zones Selected",
                    Content = "Enable at least one zone above.",
                    Duration = 3,
                    Image = 4483345998,
                })
                zoneAutoEnabled = false
                return
            end
            startZoneAutoMode()
        end
    end,
})

ZoneAutoTab:CreateLabel("Toggle zones above, then Start. Disabled zones are fully skipped.")

