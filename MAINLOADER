local alreadyNotified = {}

-- ================== CHECKER LOGIC ==================
local function runJoinChecker()
    local currentPlayers = Players:GetPlayers()
    local currentIds = {}
    for _, player in ipairs(currentPlayers) do
        currentIds[player.UserId] = player.Name
    end

    for _, watchedId in ipairs(watchedUserIds) do
        local playerName = currentIds[watchedId]

        if playerName then
            -- Player is in-game, notify only once until they leave
            if not alreadyNotified[watchedId] then
                alreadyNotified[watchedId] = true

                Rayfield:Notify({
                    Title = "🚨 PRC MODERATOR IN-GAME!",
                    Content = string.format("%s (ID: %d) is in your game!", playerName, watchedId),
                    Duration = 180,
                    Image = 4483362458
                })
                warn(string.format("[JoinChecker] PRC MODERATOR ALERT: %s (UserId: %d) has joined!", playerName, watchedId))
            end
        else
            -- Player not found, if they were notified before they've now left
            if alreadyNotified[watchedId] then
                alreadyNotified[watchedId] = nil

                local leftName = "PRC Moderator"
                pcall(function()
                    leftName = Players:GetNameFromUserIdAsync(watchedId)
                end)

                Rayfield:Notify({
                    Title = "✅ PRC Moderator Left",
                    Content = string.format("%s (ID: %d) has left the game.", leftName, watchedId),
                    Duration = 999,
                    Image = 4483362458
                })
                warn(string.format("[JoinChecker] %s (UserId: %d) has left.", leftName, watchedId))
            end
        end
    end
end

local function startChecker()
    if checkerRunning then return end
    checkerRunning = true
    alreadyNotified = {}

    task.spawn(function()
        while checkerRunning and joinCheckerEnabled do
            local ok, err = pcall(runJoinChecker)
            if not ok then
                warn("[JoinChecker] Error during scan: " .. tostring(err))
            end
            task.wait(2)
        end
        checkerRunning = false
    end)
end

local function stopChecker()
    joinCheckerEnabled = false
    checkerRunning = false
    alreadyNotified = {}
end

