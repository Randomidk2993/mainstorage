-- Helper: normalize placeId to a table
local function toIdList(val)
    if val == nil then return nil end
    if type(val) == "table" then return val end
    return { val }
end

-- Check if a value exists in a table
local function tableContains(t, value)
    for _, v in ipairs(t) do
        if v == value then return true end
    end
    return false
end

-- Load script with PlaceId check (supports single ID or table of IDs)
local function loadScript(scriptName, expectedPlaceId, scriptUrl)
    local placeIdList = toIdList(expectedPlaceId)
    local currentPlaceId = game.PlaceId

    if placeIdList and not tableContains(placeIdList, currentPlaceId) then
        Rayfield:Notify({
            Title = "Wrong Game",
            Content = string.format(
                "%s requires PlaceId(s): %s\nYour PlaceId: %d",
                scriptName,
                table.concat(placeIdList, ", "),
                currentPlaceId
            ),
            Duration = 6,
            Image = 4483362458
        })
        return
    end

    local ok, err = pcall(function()
        loadstring(game:HttpGet(scriptUrl))()
    end)

    if not ok then
        Rayfield:Notify({
            Title = "Script Error",
            Content = "Execution failed: " .. tostring(err),
            Duration = 5,
            Image = 4483362458
        })
    else
        Rayfield:Notify({
            Title = "Script Ran",
            Content = scriptName .. " executed successfully.",
            Duration = 4,
            Image = 4483362458
        })
        pcall(function()
            SoundService:PlayLocalSound(SoundService, "rbxassetid://9120386436")
        end)
    end
end

