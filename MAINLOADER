-- Services
local SoundService = game:GetService("SoundService")

-- Helper: get current PlaceId
local function getCurrentPlaceId()
    return game.PlaceId
end

-- Load script with GameId/PlaceId check
local function loadScript(scriptName, expectedPlaceId, scriptUrl)
    local currentId = getCurrentPlaceId()
    
    if expectedPlaceId and currentId ~= expectedPlaceId then
        Rayfield:Notify({
            Title = "Wrong Game",
            Content = string.format("%s requires PlaceId %d\nCurrent PlaceId: %d", scriptName, expectedPlaceId, currentId),
            Duration = 6,
            Image = 4483362458
        })
        return
    end

    local success, err = pcall(function()
        loadstring(game:HttpGet(scriptUrl))()
    end)

    if not success then
        Rayfield:Notify({
            Title = "Script Error",
            Content = "Execution failed: " .. tostring(err),
            Duration = 5,
            Image = 4483362458
        })
    else
        Rayfield:Notify({
            Title = "Script Ran",
            Content = scriptName .. " executed successfully.",
            Duration = 4,
            Image = 4483362458
        })
        pcall(function()
            SoundService:PlayLocalSound(SoundService, "rbxassetid://9120386436") -- Success chime
        end)
    end
end

