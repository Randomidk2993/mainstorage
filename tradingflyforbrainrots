-- Returns { displayName = part } for every part in BrainrotSpawn
-- Display name: "Common - Godly", "Common - Rare", etc.
local function getBrainrotSpawnZones()
    local result = {}
    local spawnFolder = workspace:FindFirstChild("Main Map")
        and workspace["Main Map"]:FindFirstChild("BrainrotSpawn")
    if not spawnFolder then return result end

    for _, category in ipairs(spawnFolder:GetChildren()) do
        for _, part in ipairs(category:GetDescendants()) do
            if part:IsA("BasePart") then
                local label = category.Name .. " - " .. part.Name
                result[label] = part
            end
        end
        -- Also handle if the category itself is a BasePart
        if category:IsA("BasePart") then
            result[category.Name] = category
        end
    end
    return result
end

-- Returns sorted list of zone display names
local function getZoneNames(zonesTable)
    local names = {}
    for name, _ in pairs(zonesTable) do
        table.insert(names, name)
    end
    table.sort(names)
    if #names == 0 then table.insert(names, "None found") end
    return names
end

-- Returns list of currently spawned brainrot names
local function getSpawnedBrainrots()
    local brainrotsFolder = workspace:FindFirstChild("Brainrots")
    local names = {}
    if brainrotsFolder then
        for _, child in ipairs(brainrotsFolder:GetChildren()) do
            table.insert(names, child.Name)
        end
    end
    table.sort(names)
    if #names == 0 then table.insert(names, "None found") end
    return names
end

-- Find player's base Collect.Touch
local function getPlayerBase()
    local basesFolder = workspace:FindFirstChild("Main Map")
        and workspace["Main Map"]:FindFirstChild("Player Bases")
    if not basesFolder then return nil end

    for _, base in ipairs(basesFolder:GetChildren()) do
        if base.Name:lower():find(player.Name:lower()) then
            for _, slot in ipairs(base:GetChildren()) do
                local collect = slot:FindFirstChild("Collect")
                if collect then
                    local touch = collect:FindFirstChild("Touch")
                    if touch then return touch end
                end
            end
        end
    end

    -- Fallback: first base found
    for _, base in ipairs(basesFolder:GetChildren()) do
        for _, slot in ipairs(base:GetChildren()) do
            local collect = slot:FindFirstChild("Collect")
            if collect then
                local touch = collect:FindFirstChild("Touch")
                if touch then return touch end
            end
        end
    end
    return nil
end

-- Steal logic
local holdDuration = 1.0

local function stealBrainrot(targetName)
    if not targetName or targetName == "" or targetName == "None found" then
        Rayfield:Notify({ Title = "Error", Content = "No brainrot selected.", Duration = 3, Image = 4483345998 })
        return
    end

    local character = player.Character or player.CharacterAdded:Wait()
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

    local targetPart, targetPrompt = nil, nil
    local searchRoot = workspace:FindFirstChild("Brainrots") or workspace

    for _, obj in ipairs(searchRoot:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower() == targetName:lower() then
            targetPart = obj
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("ProximityPrompt") and
                   (child.Name == "Pickup" or child.Name == "ProximityPrompt") then
                    targetPrompt = child
                    break
                end
            end
            if targetPrompt then break end
        end
    end

    if not targetPart then
        Rayfield:Notify({ Title = "Not Found", Content = "'" .. targetName .. "' not in workspace.", Duration = 4, Image = 4483345998 })
        return
    end

    if not targetPrompt then
        Rayfield:Notify({ Title = "No Prompt", Content = "Found part but no Pickup ProximityPrompt.", Duration = 4, Image = 4483345998 })
        return
    end

    -- Teleport to brainrot
    humanoidRootPart.CFrame = targetPart.CFrame * CFrame.new(0, 2, 0)
    task.wait(0.2)

    -- Hold prompt
    targetPrompt:InputHoldBegin()
    task.wait(holdDuration)
    targetPrompt:InputHoldEnd()
    task.wait(0.2)

    -- Return to base
    local baseTouchPart = getPlayerBase()
    if baseTouchPart then
        humanoidRootPart.CFrame = baseTouchPart.CFrame * CFrame.new(0, 3, 0)
        Rayfield:Notify({ Title = "Success", Content = "Stolen & returned to base!", Duration = 3, Image = 4483345998 })
    else
        Rayfield:Notify({ Title = "Partial Success", Content = "Picked up, but couldn't find your base.", Duration = 4, Image = 4483345998 })
    end
end

