local HUB_ZONES = {
    ["Hub - Sell"]    = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Sell") end,
    ["Hub - Shop"]    = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Shop") end,
    ["Hub - Speed"]   = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Speed") end,
    ["Hub - Carry"]   = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Carry") end,
    ["Hub - MaxFuel"] = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("MaxFuel") end,
    ["Hub - Rebirth"] = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Rebirth") end,
    ["Hub - Index"]   = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Index") end,
    ["Hub - Group"]   = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Group") end,
    ["Hub - Spins"]   = function() return workspace.MAIN_ARIGATO and workspace.MAIN_ARIGATO.parts and workspace.MAIN_ARIGATO.parts:FindFirstChild("Spins") end,
    ["My Base"]       = function() return getPlayerBase() end,
}

-- Build initial full zone list: BrainrotSpawn zones + hub zones
local function buildAllZoneOptions()
    local spawnZones = getBrainrotSpawnZones()  -- { displayName = part }
    local allNames = getZoneNames(spawnZones)

    -- Append hub zone names
    local hubNames = {}
    for name, _ in pairs(HUB_ZONES) do
        table.insert(hubNames, name)
    end
    table.sort(hubNames)
    for _, name in ipairs(hubNames) do
        table.insert(allNames, name)
    end

    return allNames, spawnZones
end

local selectedZone = ""
local currentSpawnZones = {}

local allZoneOptions, initSpawnZones = buildAllZoneOptions()
currentSpawnZones = initSpawnZones

local ZoneDropdown = ZoneTab:CreateDropdown({
    Name = "Select Zone",
    Options = allZoneOptions,
    CurrentOption = {"Select a zone..."},
    MultipleOptions = false,
    Flag = "ZoneDropdown",
    Callback = function(Options)
        selectedZone = Options[1]
    end,
})

ZoneTab:CreateButton({
    Name = "↻ Refresh Zone List",
    Callback = function()
        local fresh, freshSpawnZones = buildAllZoneOptions()
        currentSpawnZones = freshSpawnZones
        pcall(function() ZoneDropdown:Refresh(fresh, true) end)
        Rayfield:Notify({ Title = "Zones Refreshed", Content = #fresh .. " zone(s) found.", Duration = 2, Image = 4483345998 })
    end,
})

ZoneTab:CreateButton({
    Name = "Teleport to Zone",
    Callback = function()
        if selectedZone == "" or selectedZone == "None found" then
            Rayfield:Notify({ Title = "Error", Content = "Please select a zone first.", Duration = 3, Image = 4483345998 })
            return
        end

        local character = player.Character or player.CharacterAdded:Wait()
        local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

        -- Resolve the part: check BrainrotSpawn zones first, then hub zones
        local zonePart = nil

        if currentSpawnZones[selectedZone] then
            -- Direct BasePart from BrainrotSpawn
            zonePart = currentSpawnZones[selectedZone]
        elseif HUB_ZONES[selectedZone] then
            -- Hub zone via getter function
            zonePart = HUB_ZONES[selectedZone]()
        end

        if not zonePart then
            Rayfield:Notify({ Title = "Zone Not Found", Content = "'" .. selectedZone .. "' could not be located.", Duration = 4, Image = 4483345998 })
            return
        end

        -- Resolve CFrame
        local targetCFrame = nil
        if zonePart:IsA("BasePart") then
            targetCFrame = zonePart.CFrame
        elseif zonePart:IsA("Model") and zonePart.PrimaryPart then
            targetCFrame = zonePart.PrimaryPart.CFrame
        else
            for _, c in ipairs(zonePart:GetDescendants()) do
                if c:IsA("BasePart") then
                    targetCFrame = c.CFrame
                    break
                end
            end
        end

        if not targetCFrame then
            Rayfield:Notify({ Title = "Error", Content = "Couldn't get a position for this zone.", Duration = 3, Image = 4483345998 })
            return
        end

        humanoidRootPart.CFrame = targetCFrame * CFrame.new(0, 4, 0)
        Rayfield:Notify({ Title = "Teleported!", Content = "Arrived at " .. selectedZone, Duration = 2, Image = 4483345998 })
    end,
})

ZoneTab:CreateLabel("Zones auto-loaded from BrainrotSpawn. Refresh if needed.")
