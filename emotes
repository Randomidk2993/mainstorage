-- ============================================================
--  🤪 GOOFY ANIM HUB  v10
--  Emotes  : HumanoidDescription bypass (any game)
--  Loco    : Catalog API bundle resolver + correct sync method:
--              1. Write IDs into Animate folder (source of truth)
--              2. Stop currently playing loco tracks so Animate
--                 script is forced to re-load from folder on next
--                 cycle — this is what actually replicates
--              3. ApplyDescription as a second layer for clients
--                 that watch HumDesc instead of Animator events
--  Speed   : Heartbeat AdjustSpeed loop
--  Freeze  : Forces emote to keep playing even while walking
-- ============================================================

local ok0, Rayfield = pcall(function()
    return loadstring(game:HttpGet(
        "https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua"
    ))()
end)
if not ok0 or not Rayfield then warn("[GoofyHub] Rayfield failed") return end

local Players     = game:GetService("Players")
local RunService  = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local LP          = Players.LocalPlayer

-- ──────────────────────────────────────────────────────────
--  REFS
-- ──────────────────────────────────────────────────────────
local Char, Hum, HumDesc, Animator, Animate

local function refresh()
    Char     = LP.Character
    if not Char then return false end
    Hum      = Char:FindFirstChildOfClass("Humanoid")
    HumDesc  = Hum  and Hum:FindFirstChildOfClass("HumanoidDescription")
    Animator = Hum  and Hum:FindFirstChildOfClass("Animator")
    Animate  = Char:FindFirstChild("Animate")
    return Hum ~= nil
end
refresh()

-- ──────────────────────────────────────────────────────────
--  BUNDLE → ANIMATION RESOLVER  (Catalog API + GetObjects)
-- ──────────────────────────────────────────────────────────
local bundleCache = {}

local LOCO_KEYWORDS = {
    walk  = { "walk" },
    run   = { "run"  },
    idle  = { "idle" },
    jump  = { "jump" },
    fall  = { "fall", "falling" },
    climb = { "climb" },
    swim  = { "swim"  },
}

local function matchCategory(name)
    local low = name:lower()
    for cat, keys in pairs(LOCO_KEYWORDS) do
        for _, k in ipairs(keys) do
            if low:find(k) then return cat end
        end
    end
    return nil
end

local function extractId(str)
    return str and tostring(str):match("%d+")
end

local function harvestAnimations(root, result)
    local function recurse(inst)
        if inst:IsA("Animation") then
            local animId = extractId(inst.AnimationId)
            if animId then
                local cat = matchCategory(inst.Name)
                         or (inst.Parent and matchCategory(inst.Parent.Name))
                if cat and not result[cat] then
                    result[cat] = animId
                end
            end
        end
        for _, child in ipairs(inst:GetChildren()) do recurse(child) end
    end
    recurse(root)
end

local function fetchBundleAssetIds(bundleId)
    local url = "https://catalog.roblox.com/v1/bundles/" .. tostring(bundleId) .. "/details"
    local ok, raw = pcall(function() return game:HttpGet(url) end)
    if not ok or not raw then
        warn("[GoofyHub] HttpGet failed for bundle " .. tostring(bundleId))
        return nil
    end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or not data then
        warn("[GoofyHub] JSON decode failed for bundle " .. tostring(bundleId))
        return nil
    end
    local assetIds = {}
    if data.items then
        for _, item in ipairs(data.items) do
            if item.type == "Asset" and item.id then
                table.insert(assetIds, tostring(item.id))
            end
        end
    end
    if #assetIds == 0 then
        warn("[GoofyHub] Bundle " .. tostring(bundleId) .. " returned no asset items.")
    end
    return assetIds
end

local function resolveBundle(bundleId)
    local id = tostring(bundleId)
    if bundleCache[id] then return bundleCache[id] end
    local result = {}
    local assetIds = fetchBundleAssetIds(id)
    if not assetIds or #assetIds == 0 then
        bundleCache[id] = result
        return result
    end
    for _, assetId in ipairs(assetIds) do
        local ok, objs = pcall(function()
            return game:GetObjects("rbxassetid://" .. assetId)
        end)
        if ok and objs then
            for _, obj in ipairs(objs) do
                harvestAnimations(obj, result)
                pcall(function() obj:Destroy() end)
            end
        end
    end
    bundleCache[id] = result
    return result
end

-- ──────────────────────────────────────────────────────────
--  LOCO ANIM SETTER
--
--  The correct sync strategy (confirmed by how Roblox's own
--  Animate LocalScript works):
--
--  1. Write the new AnimationId into the Animate folder child.
--     The Animate script reads these values when it decides
--     which animation to play — this is the source of truth.
--
--  2. Stop every currently-playing loco track on the Animator.
--     This forces the Animate script's internal state machine
--     to re-enter, re-read the folder IDs, load a fresh track,
--     and call :Play() — which fires a replication event that
--     OTHER clients actually see via their Animator listeners.
--
--  3. Also call ApplyDescription so the HumDesc properties
--     match, covering any client that watches HumDesc changes
--     rather than Animator events (some custom rigs do this).
--     We do NOT rely on ApplyDescription alone for replication
--     because in server-auth games the server rejects it.
--
--  Reset works identically — write DEFAULT_LOCO IDs then stop
--  tracks, so other clients see your character snap back to
--  default animations immediately.
-- ──────────────────────────────────────────────────────────
local DEFAULT_LOCO = {
    walk  = 507777826,
    run   = 507767714,
    idle  = 507766388,
    jump  = 507765000,
    fall  = 507767968,
    climb = 507765644,
}

local DESC_PROP = {
    walk  = "WalkAnimationId",
    run   = "RunAnimationId",
    idle  = "IdleAnimationId",
    jump  = "JumpAnimationId",
    fall  = "FallAnimationId",
    climb = "ClimbAnimationId",
    swim  = "SwimAnimationId",
}

-- Names of Animate folder → Animator track name mapping
-- The Animate script names its tracks after the folder they came from
local LOCO_TRACK_NAMES = {
    walk  = true, run   = true, idle  = true,
    jump  = true, fall  = true, climb = true, swim = true,
}

local appliedLoco = {}  -- [animType] = animId, persists across respawn

local emoteTrackRef = nil  -- forward-declared; set by emote system below

-- Stop all currently-playing locomotion tracks so Animate re-loads them.
-- We skip the emote track so we don't kill an active emote.
local function stopLocoTracks()
    if not Animator then return end
    for _, track in ipairs(Animator:GetPlayingAnimationTracks()) do
        if track ~= emoteTrackRef then
            -- Only stop tracks whose name matches a loco category
            local name = track.Name and track.Name:lower() or ""
            for cat in pairs(LOCO_TRACK_NAMES) do
                if name:find(cat) then
                    pcall(function() track:Stop(0) end)  -- 0 = instant, no fade
                    break
                end
            end
        end
    end
end

-- Write IDs directly into the Animate folder children.
-- Returns a snapshot { [animType] = oldAnimationId } so caller can restore.
local function writeAnimateFolders(slots)
    local snapshot = {}
    if not Animate then return snapshot end
    for animType, animId in pairs(slots) do
        local folder = Animate:FindFirstChild(animType)
        if folder then
            for _, child in ipairs(folder:GetChildren()) do
                if child:IsA("Animation") then
                    snapshot[animType] = child.AnimationId
                    pcall(function()
                        child.AnimationId = "rbxassetid://" .. tostring(animId)
                    end)
                end
            end
        end
    end
    return snapshot
end

-- Core apply: ApplyDescription FIRST (so it can't clobber our folder write),
-- then write Animate folders (our IDs always win), then stop loco tracks.
local function applySlots(slots)
    if not refresh() then return end

    -- Step 1: ApplyDescription FIRST — some games internally reset the Animate
    -- script when this fires. Doing it before the folder write means it cannot
    -- overwrite our IDs. It also covers HumDesc-watching clients.
    local ok, desc = pcall(function() return Hum:GetAppliedDescription() end)
    if ok and desc then
        local clone = desc:Clone()
        for animType, animId in pairs(slots) do
            local prop = DESC_PROP[animType]
            if prop then
                pcall(function() clone[prop] = tonumber(animId) or 0 end)
            end
        end
        pcall(function() Hum:ApplyDescription(clone) end)
        pcall(function() clone:Destroy() end)
        -- Re-grab refs — ApplyDescription can recreate Animate in some games
        refresh()
    end

    -- Step 2: Write Animate folders — always last so our IDs win over anything
    -- ApplyDescription may have reset. Animate script reads these on next cycle.
    writeAnimateFolders(slots)

    -- Step 3: Stop loco tracks — forces Animate to re-read folders, load fresh
    -- tracks, and :Play() them. That :Play() is the replicated event others see.
    stopLocoTracks()
end

-- ── Public helpers ────────────────────────────────────────

local function applySlot(animType, animId)
    if not refresh() then return end
    applySlots({ [animType] = animId })
    appliedLoco[animType] = animId
end

local function applyBundle(bundleId)
    if not refresh() then return end
    Rayfield:Notify({
        Title    = "🔄 Resolving bundle...",
        Content  = "Fetching catalog details for ID: " .. tostring(bundleId),
        Duration = 3,
    })
    task.spawn(function()
        local map = resolveBundle(bundleId)
        local count = 0
        for _ in pairs(map) do count = count + 1 end
        if count > 0 then
            applySlots(map)
            for cat, animId in pairs(map) do
                appliedLoco[cat] = animId
            end
            Rayfield:Notify({
                Title   = "✅ Bundle Applied",
                Content = count .. " animation slot(s) set!",
                Duration = 3,
            })
        else
            Rayfield:Notify({
                Title   = "⚠️ No Anims Found",
                Content = "Bundle " .. tostring(bundleId) .. " had no locomotion anims.",
                Duration = 4,
            })
        end
    end)
end

local function resetAllLoco()
    if not refresh() then return end
    -- Write ALL default slots at once, then stop tracks once
    applySlots(DEFAULT_LOCO)
    appliedLoco = {}
end

-- Respawn: re-apply whatever was set before death
_G.GoofyLocoReapply = function()
    if next(appliedLoco) == nil then return end
    if not refresh() then return end
    applySlots(appliedLoco)
end

LP.CharacterAdded:Connect(function()
    task.wait(1.5)   -- wait for Animate script to fully start
    refresh()
    _G.GoofyLocoReapply()
end)

-- ──────────────────────────────────────────────────────────
--  SPEED LOOP
-- ──────────────────────────────────────────────────────────
local speedTarget = 1
local speedConn   = nil

local function applySpeedNow()
    if not Animator then refresh() return end
    for _, t in ipairs(Animator:GetPlayingAnimationTracks()) do
        if t ~= emoteTrackRef then
            pcall(function() t:AdjustSpeed(speedTarget) end)
        end
    end
end

local function startSpeedLoop()
    if speedConn then speedConn:Disconnect() end
    speedConn = RunService.Heartbeat:Connect(applySpeedNow)
end

local function stopSpeedLoop()
    if speedConn then speedConn:Disconnect() speedConn = nil end
    if Animator then
        for _, t in ipairs(Animator:GetPlayingAnimationTracks()) do
            if t ~= emoteTrackRef then
                pcall(function() t:AdjustSpeed(1) end)
            end
        end
    end
end

local function setSpeed(s)
    speedTarget = s
    if s == 1 then stopSpeedLoop() else startSpeedLoop() end
end

-- ──────────────────────────────────────────────────────────
--  EMOTE SYSTEM
-- ──────────────────────────────────────────────────────────
local emoteTrack  = nil
local lastEmoteId = nil
local loopEmote   = true
local emoteSpeed  = 1
local freezeOn    = false

local function stopEmote()
    if emoteTrack then
        pcall(function() emoteTrack:Stop() end)
        emoteTrack    = nil
        emoteTrackRef = nil
    end
    -- Re-apply any active bundle/loco overrides so Animate picks them back up
    if next(appliedLoco) ~= nil then
        task.defer(function()
            if next(appliedLoco) ~= nil and refresh() then
                writeAnimateFolders(appliedLoco)
                stopLocoTracks()
            end
        end)
    end
end

local function _firePlay(idNum)
    if not refresh() then return nil end

    -- Snapshot current Animate folder IDs before touching HumDesc.
    -- SetEmotes/SetEquippedEmotes can trigger an internal Animate reset in
    -- some games, which would wipe any bundle IDs we wrote. We restore after.
    local snapshot = {}
    if Animate then
        for cat in pairs(LOCO_TRACK_NAMES) do
            local folder = Animate:FindFirstChild(cat)
            if folder then
                for _, child in ipairs(folder:GetChildren()) do
                    if child:IsA("Animation") then
                        snapshot[cat] = child.AnimationId
                    end
                end
            end
        end
    end

    -- HumanoidDescription bypass
    pcall(function()
        HumDesc:SetEmotes({ _GoofySlot = { idNum } })
        HumDesc:SetEquippedEmotes({ "_GoofySlot" })
    end)

    -- Restore folder IDs in case SetEmotes reset them
    if Animate then
        for cat, savedId in pairs(snapshot) do
            local folder = Animate:FindFirstChild(cat)
            if folder then
                for _, child in ipairs(folder:GetChildren()) do
                    if child:IsA("Animation") and child.AnimationId ~= savedId then
                        pcall(function() child.AnimationId = savedId end)
                    end
                end
            end
        end
    end

    -- Primary: native emote pipeline
    -- Returns boolean true in many games, NOT the track — use typeof guard
    local ok2, result = pcall(function()
        return Hum:PlayEmoteAndGetAnimTrackById(idNum)
    end)
    if ok2 and result and typeof(result) == "Instance" and result:IsA("AnimationTrack") then
        return result
    end

    -- Fallback: direct Animator load (always returns a real track)
    if not Animator then return nil end
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(idNum)
    local ok3, t2 = pcall(function() return Animator:LoadAnimation(anim) end)
    if ok3 and t2 and typeof(t2) == "Instance" and t2:IsA("AnimationTrack") then
        t2:Play()
        return t2
    end

    return nil
end

local function playEmote(id)
    if not refresh() then
        Rayfield:Notify({ Title = "⚠️", Content = "No character!", Duration = 3 })
        return false
    end
    if not HumDesc then
        Rayfield:Notify({ Title = "⚠️", Content = "No HumanoidDescription!", Duration = 3 })
        return false
    end

    stopEmote()

    local idNum = tonumber(extractId(tostring(id)))
    if not idNum then return false end

    local track = _firePlay(idNum)
    if not track then
        Rayfield:Notify({ Title = "❌ Failed", Content = "Could not play emote ID " .. idNum, Duration = 4 })
        return false
    end

    emoteTrack    = track
    emoteTrackRef = track
    lastEmoteId   = idNum
    track.Looped   = loopEmote
    track.Priority = Enum.AnimationPriority.Action4
    pcall(function() track:AdjustSpeed(emoteSpeed) end)

    local capturedTrack = track
    track.Stopped:Connect(function()
        if emoteTrack == capturedTrack and not freezeOn then
            emoteTrack    = nil
            emoteTrackRef = nil
            -- Restore bundle anims so Animate doesn't fall back to defaults
            if next(appliedLoco) ~= nil then
                task.defer(function()
                    if next(appliedLoco) ~= nil and refresh() then
                        writeAnimateFolders(appliedLoco)
                        stopLocoTracks()
                    end
                end)
            end
        end
    end)

    return true
end

-- ──────────────────────────────────────────────────────────
--  WALK-FREEZE SYSTEM
-- ──────────────────────────────────────────────────────────
local freezeConn = nil

local function startFreeze()
    if not lastEmoteId then
        Rayfield:Notify({ Title = "⚠️ No Emote", Content = "Play an emote first!", Duration = 3 })
        return
    end
    freezeOn = true
    if freezeConn then freezeConn:Disconnect() end
    freezeConn = RunService.Heartbeat:Connect(function()
        if not freezeOn then return end
        if not refresh() then return end
        if emoteTrack and emoteTrack.IsPlaying then
            pcall(function() emoteTrack.Priority = Enum.AnimationPriority.Action4 end)
            pcall(function() emoteTrack:AdjustSpeed(emoteSpeed) end)
        else
            local track = _firePlay(lastEmoteId)
            if track then
                emoteTrack    = track
                emoteTrackRef = track
                track.Looped   = loopEmote
                track.Priority = Enum.AnimationPriority.Action4
                pcall(function() track:AdjustSpeed(emoteSpeed) end)
            end
        end
    end)
end

local function stopFreeze()
    freezeOn = false
    if freezeConn then freezeConn:Disconnect() freezeConn = nil end
end

