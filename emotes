ST:CreateSection("Goofy Modes")

local moonOn   = false
local moonConn = nil
ST:CreateButton({
    Name     = "🌕  Moonwalk (reverse loco)",
    Callback = function()
        if moonOn then
            moonOn = false
            if moonConn then moonConn:Disconnect() moonConn = nil end
            if Animator then
                for _, t in ipairs(Animator:GetPlayingAnimationTracks()) do
                    if t ~= emoteTrackRef then
                        pcall(function() t:AdjustSpeed(math.abs(speedTarget)) end)
                    end
                end
            end
            Rayfield:Notify({ Title = "🌕 Moonwalk OFF", Content = "Normal restored.", Duration = 2 })
        else
            moonOn = true
            stopSpeedLoop()
            moonConn = RunService.Heartbeat:Connect(function()
                if not Animator then refresh() return end
                for _, t in ipairs(Animator:GetPlayingAnimationTracks()) do
                    if t ~= emoteTrackRef then
                        pcall(function() t:AdjustSpeed(-math.abs(speedTarget)) end)
                    end
                end
            end)
            Rayfield:Notify({ Title = "🌕 Moonwalk ON!", Content = "Animations play in reverse!", Duration = 2 })
        end
    end,
})

local drunkOn   = false
local drunkConn = nil
ST:CreateButton({
    Name     = "🥴  Drunk Mode (random speed)",
    Callback = function()
        if drunkOn then
            drunkOn = false
            if drunkConn then drunkConn:Disconnect() drunkConn = nil end
            if Animator then
                for _, t in ipairs(Animator:GetPlayingAnimationTracks()) do
                    if t ~= emoteTrackRef then
                        pcall(function() t:AdjustSpeed(speedTarget) end)
                    end
                end
            end
            Rayfield:Notify({ Title = "🥴 Drunk OFF", Content = "Normal restored.", Duration = 2 })
        else
            drunkOn = true
            stopSpeedLoop()
            local timer = 0
            local nextSpd = 1
            drunkConn = RunService.Heartbeat:Connect(function(dt)
                if not Animator then refresh() return end
                timer = timer - dt
                if timer <= 0 then
                    nextSpd = math.random(5, 30) / 10
                    timer   = math.random(8, 35) / 100
                end
                for _, t in ipairs(Animator:GetPlayingAnimationTracks()) do
                    if t ~= emoteTrackRef then
                        pcall(function() t:AdjustSpeed(nextSpd) end)
                    end
                end
            end)
            Rayfield:Notify({ Title = "🥴 Drunk ON!", Content = "Random speed active!", Duration = 2 })
        end
    end,
})

ST:CreateButton({
    Name     = "⏸️  Freeze All Loco",
